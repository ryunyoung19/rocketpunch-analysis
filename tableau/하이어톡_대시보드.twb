            <column-instance column='[신규기업_비교라벨(복사본)(2 복사본)_6743112061923358]' derivation='User' name='[usr:신규기업_비교라벨(복사본)(2 복사본)_6743112061923358:nk]' pivot='key' type='nominal' />
