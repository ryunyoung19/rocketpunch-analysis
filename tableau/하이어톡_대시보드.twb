            <datasource caption='매개 변수' name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='비교 기준 선택' datatype='string' name='[분포 기준 선택(2 복사본)]' param-domain-type='list' role='measure' type='nominal' value='&quot;전월&quot;'>
              <calculation class='tableau' formula='&quot;전월&quot;' />
            </column>
            <column caption='기준 월' datatype='date' default-format='*yyyy.mm' name='[분포 기준 선택(복사본)]' param-domain-type='any' role='measure' type='quantitative' value='#2022-01-01#'>
              <calculation class='tableau' formula='#2022-01-01#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.11b16ft0k5zkh9163gmnf1cg97fy'>
            <column caption='기준월_날짜' datatype='date' name='[Calculation_0835367110733824]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE(DATEPARSE(&quot;yyyy-MM&quot;, [month]))' />
            </column>
            <column caption='Month' datatype='string' name='[month]' role='dimension' type='nominal' />
            <column caption='New Users' datatype='integer' name='[new_users]' role='measure' type='quantitative' />
            <column-instance column='[신규기업_비교라벨(복사본)_6743112061902876]' derivation='User' name='[usr:신규기업_비교라벨(복사본)_6743112061902876:nk]' pivot='key' type='nominal' />
            <column-instance column='[신규기업_증감상태(3 복사본)_6743112064974882]' derivation='User' name='[usr:신규기업_증감상태(3 복사본)_6743112064974882:nk]' pivot='key' type='nominal' />
            <column caption='신규유저_비교값' datatype='integer' name='[신규기업_비교값(복사본)_6743112058015768]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[분포 기준 선택(2 복사본)]&#10;WHEN &apos;전월&apos; THEN [신규기업_전월값(2 복사본)_6743112055111693]&#10;WHEN &apos;전년동월&apos; THEN [신규기업_전년동월값(복사본)_6743112055918608]&#10;END' />
            </column>
            <column caption='신규유저_비교라벨' datatype='string' name='[신규기업_비교라벨(복사본)_6743112061902876]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [신규기업_증감률(3 복사본)_6743112057757719] &gt; 0 THEN&#10;    &quot;▲ &quot; + [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 &quot; + STR(ROUND([신규기업_증감률(3 복사본)_6743112057757719] * 100, 1)) + &quot;%&quot;&#10;ELSEIF [신규기업_증감률(3 복사본)_6743112057757719] &lt; 0 THEN&#10;    &quot;▼ &quot; + [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 &quot; + STR(ROUND(ABS([신규기업_증감률(3 복사본)_6743112057757719] * 100), 1)) + &quot;%&quot;&#10;ELSE&#10;    &quot;→ &quot; + [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 0.0%&quot;&#10;END' />
            </column>
            <column caption='신규유저_전년동월값' datatype='integer' name='[신규기업_전년동월값(복사본)_6743112055918608]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#10;    IF [Calculation_0835367110733824] = DATEADD(&apos;year&apos;, -1, DATETRUNC(&apos;month&apos;, [Parameters].[분포 기준 선택(복사본)]))&#10;    THEN [new_users]&#10;    END&#10;)' />
            </column>
            <column caption='신규유저_전월값' datatype='integer' name='[신규기업_전월값(2 복사본)_6743112055111693]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#10;    IF [Calculation_0835367110733824] = DATEADD(&apos;month&apos;, -1, DATETRUNC(&apos;month&apos;, [Parameters].[분포 기준 선택(복사본)]))&#10;    THEN [new_users]&#10;    END&#10;)' />
            </column>
            <column caption='신규유저_증감률' datatype='real' name='[신규기업_증감률(3 복사본)_6743112057757719]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ISNULL([신규기업_비교값(복사본)_6743112058015768]) OR [신규기업_비교값(복사본)_6743112058015768] = 0 THEN&#10;    0&#10;ELSE&#10;    ([신규기업_현재값(2 복사본)_6743112054456329] - [신규기업_비교값(복사본)_6743112058015768]) / [신규기업_비교값(복사본)_6743112058015768]&#10;END' />
            </column>
            <column caption='신규유저_증감상태' datatype='string' name='[신규기업_증감상태(3 복사본)_6743112064974882]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [신규기업_증감률(3 복사본)_6743112057757719] &lt; 0 THEN&#10;    [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 하락&quot;&#10;ELSEIF [신규기업_증감률(3 복사본)_6743112057757719] &gt; 0 THEN&#10;    [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 상승&quot;&#10;ELSE&#10;    [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 변화없음&quot;&#10;END' />
            </column>
            <column caption='신규유저_현재값' datatype='integer' name='[신규기업_현재값(2 복사본)_6743112054456329]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#10;    IF [Calculation_0835367110733824] = DATETRUNC(&apos;month&apos;, [Parameters].[분포 기준 선택(복사본)])&#10;    THEN [new_users]&#10;    END&#10;)' />
