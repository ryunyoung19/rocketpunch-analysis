      <column caption='신규유입_라벨' datatype='string' name='[Calculation_0835367111008257]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([new_users_mom_rate]) &gt; 0 THEN&#10;    &quot;▲ 전월 대비 &quot; + STR(ROUND(AVG([new_users_mom_rate]), 1)) + &quot;%&quot;&#10;ELSEIF AVG([new_users_mom_rate]) &lt; 0 THEN&#10;    &quot;▼ 전월 대비 &quot; + STR(ROUND(ABS(AVG([new_users_mom_rate])), 1)) + &quot;%&quot;&#10;ELSE&#10;    &quot;→ 전월 대비 0.0%&quot;&#10;END' />
