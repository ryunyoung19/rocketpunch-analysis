            <column caption='신규공고_비교값' datatype='integer' name='[신규기업_비교값(2 복사본)_6743112058023961]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[분포 기준 선택(2 복사본)]&#10;WHEN &apos;전월&apos; THEN [신규기업_전월값(복사본)_6743112055103500]&#10;WHEN &apos;전년동월&apos; THEN [신규유저_전년동월값(복사본)_6743112056066065]&#10;END' />
            </column>
            <column caption='신규공고_비교라벨' datatype='string' name='[신규기업_비교라벨(복사본)(2 복사본)_6743112061923358]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [신규기업_증감률(2 복사본)_6743112057749526] &gt; 0 THEN&#10;    &quot;▲ &quot; + [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 &quot; + STR(ROUND([신규기업_증감률(2 복사본)_6743112057749526] * 100, 1)) + &quot;%&quot;&#10;ELSEIF [신규기업_증감률(2 복사본)_6743112057749526] &lt; 0 THEN&#10;    &quot;▼ &quot; + [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 &quot; + STR(ROUND(ABS([신규기업_증감률(2 복사본)_6743112057749526] * 100), 1)) + &quot;%&quot;&#10;ELSE&#10;    &quot;→ &quot; + [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 0.0%&quot;&#10;END' />
            </column>
            <column caption='신규공고_전월값' datatype='integer' name='[신규기업_전월값(복사본)_6743112055103500]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#10;    IF [Calculation_0835367110733824] = DATEADD(&apos;month&apos;, -1, DATETRUNC(&apos;month&apos;, [Parameters].[분포 기준 선택(복사본)]))&#10;    THEN [new_jobs]&#10;    END&#10;)' />
            </column>
            <column caption='신규공고_증감률' datatype='real' name='[신규기업_증감률(2 복사본)_6743112057749526]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ISNULL([신규기업_비교값(2 복사본)_6743112058023961]) OR [신규기업_비교값(2 복사본)_6743112058023961] = 0 THEN&#10;    0&#10;ELSE&#10;    ([신규기업_현재값(3 복사본)_6743112054476810] - [신규기업_비교값(2 복사본)_6743112058023961]) / [신규기업_비교값(2 복사본)_6743112058023961]&#10;END' />
            </column>
            <column caption='신규공고_증감상태' datatype='string' name='[신규기업_증감상태(2 복사본)_6743112064966689]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [신규기업_증감률(2 복사본)_6743112057749526] &lt; 0 THEN&#10;    [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 하락&quot;&#10;ELSEIF [신규기업_증감률(2 복사본)_6743112057749526] &gt; 0 THEN&#10;    [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 상승&quot;&#10;ELSE&#10;    [Parameters].[분포 기준 선택(2 복사본)] + &quot; 대비 변화없음&quot;&#10;END' />
            </column>
            <column caption='신규공고_현재값' datatype='integer' name='[신규기업_현재값(3 복사본)_6743112054476810]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#10;    IF [Calculation_0835367110733824] = DATETRUNC(&apos;month&apos;, [Parameters].[분포 기준 선택(복사본)])&#10;    THEN [new_jobs]&#10;    END&#10;)' />
