          <datasource-dependencies datasource='Parameters'>
            <column caption='기준 날짜' datatype='date' name='[매개 변수 1]' param-domain-type='any' role='measure' type='quantitative' value='#2022-01-05#'>
              <calculation class='tableau' formula='#2022-01-05#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.167l7r01yhxbls11him6f02k3dwo'>
            <column aggregation='CountD' caption='선택 날짜 신규 기업' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_5023887845679105]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATE([cdate]) = [Parameters].[매개 변수 1] THEN [company_uuid] END' />
            </column>
            <column aggregation='CountD' caption='전일 신규 기업 ' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_5023887859068935]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATE([cdate]) = DATEADD(&apos;day&apos;, -1, [Parameters].[매개 변수 1]) THEN [company_uuid] END' />
            </column>
            <column caption='전일 대비 증감률' datatype='real' name='[Calculation_5023887859638280]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF COUNTD([Calculation_5023887859068935]) = 0 THEN NULL&#10;ELSE&#10;    (&#10;        COUNTD([Calculation_5023887845679105]) - COUNTD([Calculation_5023887859068935])&#10;    )&#10;    /&#10;    COUNTD([Calculation_5023887859068935])&#10;END' />
            </column>
            <column caption='전일 대비 라벨' datatype='string' name='[Calculation_5023887860494345]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_5023887859638280] &gt; 0 THEN&#10;    &quot;▲ 전일 대비 &quot; + STR(ROUND([Calculation_5023887859638280] * 100, 1)) + &quot;%&quot;&#10;ELSEIF [Calculation_5023887859638280] &lt; 0 THEN&#10;    &quot;▼ 전일 대비 &quot; + STR(ROUND(ABS([Calculation_5023887859638280] * 100), 1)) + &quot;%&quot;&#10;ELSE&#10;    &quot;→ 전일 대비 0.0%&quot;&#10;END' />
            </column>
            <column caption='전일 대비 색상' datatype='string' name='[Calculation_5023887882895375]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([Calculation_5023887859638280]) THEN&#10;    &quot;기타&quot;&#10;ELSEIF [Calculation_5023887859638280] &lt; 0 THEN&#10;    &quot;하락&quot;&#10;ELSEIF [Calculation_5023887859638280] &gt; 0 THEN&#10;    &quot;상승&quot;&#10;ELSE&#10;    &quot;변화없음&quot;&#10;END' />
            </column>
            <column caption='Cdate' datatype='datetime' name='[cdate]' role='dimension' type='ordinal' />
            <column aggregation='CountD' caption='Company Uuid' datatype='string' default-role='measure' default-type='quantitative' name='[company_uuid]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_5023887860494345]' derivation='User' name='[usr:Calculation_5023887860494345:nk]' pivot='key' type='nominal' />
