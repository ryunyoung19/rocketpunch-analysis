      <aliases enabled='yes' />
      <column aggregation='CountD' caption='선택 날짜 신규 기업' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_5023887845679105]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATE([cdate]) = [Parameters].[매개 변수 1] THEN [company_uuid] END' />
      </column>
      <column caption='표시 기간' datatype='boolean' name='[Calculation_5023887848427525]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATE([cdate]) &gt;= #2022-01-01#&#10;AND DATE([cdate]) &lt;= #2023-12-31#' />
      </column>
      <column aggregation='CountD' caption='누적 날짜' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_5023887853834246]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATE([cdate]) &lt;= [Parameters].[매개 변수 1] THEN [company_uuid] END' />
      </column>
      <column aggregation='CountD' caption='전일 신규 기업 ' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_5023887859068935]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATE([cdate]) = DATEADD(&apos;day&apos;, -1, [Parameters].[매개 변수 1]) THEN [company_uuid] END' />
      </column>
      <column caption='전일 대비 증감률' datatype='real' name='[Calculation_5023887859638280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF COUNTD([Calculation_5023887859068935]) = 0 THEN NULL&#10;ELSE&#10;    (&#10;        COUNTD([Calculation_5023887845679105]) - COUNTD([Calculation_5023887859068935])&#10;    )&#10;    /&#10;    COUNTD([Calculation_5023887859068935])&#10;END' />
      </column>
      <column caption='전일 대비 라벨' datatype='string' name='[Calculation_5023887860494345]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_5023887859638280] &gt; 0 THEN&#10;    &quot;▲ 전일 대비 &quot; + STR(ROUND([Calculation_5023887859638280] * 100, 1)) + &quot;%&quot;&#10;ELSEIF [Calculation_5023887859638280] &lt; 0 THEN&#10;    &quot;▼ 전일 대비 &quot; + STR(ROUND(ABS([Calculation_5023887859638280] * 100), 1)) + &quot;%&quot;&#10;ELSE&#10;    &quot;→ 전일 대비 0.0%&quot;&#10;END' />
      </column>
      <column aggregation='CountD' caption='기업 상세 라벨' datatype='string' name='[Calculation_5023887860776970]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;→ 기업 상세&quot;' />
      </column>
      <column aggregation='CountD' caption='카드제목' datatype='string' name='[Calculation_5023887863812107]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;신규 기업 등록&quot;' />
      </column>
      <column aggregation='CountD' caption='선택 월 신규 기업' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_5023887881535500]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;month&apos;, [cdate]) = DATETRUNC(&apos;month&apos;, [Parameters].[매개 변수 1]) THEN [company_uuid] END' />
      </column>
      <column caption='전월 대비 증감률' datatype='real' name='[Calculation_5023887881834509]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF COUNTD([Calculation_5023887859068935]) = 0 THEN NULL&#10;ELSE&#10;    (&#10;        COUNTD([Calculation_5023887881535500]) - COUNTD([Calculation_5023887859068935])&#10;    )&#10;    /&#10;    COUNTD([Calculation_5023887859068935])&#10;END' />
      </column>
      <column caption='전월 대비 라벨' datatype='string' name='[Calculation_5023887882096654]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Calculation_5023887881834509]) THEN&#10;    &quot;→ 전월 데이터 없음&quot;&#10;ELSEIF [Calculation_5023887881834509] &gt; 0 THEN&#10;    &quot;▲ 전월 대비 &quot; + STR(ROUND([Calculation_5023887881834509] * 100, 1)) + &quot;%&quot;&#10;ELSEIF [Calculation_5023887881834509] &lt; 0 THEN&#10;    &quot;▼ 전월 대비 &quot; + STR(ROUND(ABS([Calculation_5023887881834509] * 100), 1)) + &quot;%&quot;&#10;ELSE&#10;    &quot;→ 전월 대비 0.0%&quot;&#10;END' />
